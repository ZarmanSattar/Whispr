# E2E test environment variables
# Create this file at the root of the project (same level as package.json)
# NEVER commit this file — it is in .gitignore

# The URL to run E2E tests against
PLAYWRIGHT_BASE_URL=http://localhost:3000

# A dedicated test Clerk account — create a separate account just for testing
# Use a throwaway email — this account will be used to create/delete interviews
TEST_EMAIL=your-test-account@email.com
TEST_PASSWORD=YourTestPassword123!
